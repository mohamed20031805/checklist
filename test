def _add_doc_sheet(self, wb, sheet_name, full_path, sec_name, task_name, basename):
    ws  = wb.create_sheet(title=sheet_name)
    col = SECTION_COLORS.get(sec_name, SG_RED)

    def xf(h):     return PatternFill("solid", fgColor=h.lstrip("#"))
    def font(**k): return Font(name="Arial", **k)

    # ── Header ──
    ws.merge_cells("A1:F1")
    ws["A1"] = f"Document  ·  {sec_name}  /  {task_name}"
    ws["A1"].font      = font(size=11, bold=True, color="FFFFFF")
    ws["A1"].fill      = xf(col)
    ws["A1"].alignment = Alignment(horizontal="center", vertical="center")
    ws.row_dimensions[1].height = 28

    for i, (lbl, val) in enumerate([
        ("File",        basename),
        ("Section",     sec_name),
        ("Task",        task_name),
        ("Imported on", datetime.now().strftime("%d/%m/%Y %H:%M")),
    ], 2):
        ws[f"A{i}"] = lbl; ws[f"A{i}"].font = font(size=9, bold=True, color="5A5A5A")
        ws[f"B{i}"] = val; ws[f"B{i}"].font = font(size=9)
        ws.row_dimensions[i].height = 16

    ws.column_dimensions["A"].width = 16
    ws.column_dimensions["B"].width = 52

    ext = os.path.splitext(full_path)[1].lower()

    # ── Image → intégrée directement ──
    if ext in (".png", ".jpg", ".jpeg", ".bmp", ".gif"):
        try:
            img = XLImage(full_path)
            img.anchor = "A7"
            for max_d in [(600, "width"), (750, "height")]:
                if getattr(img, max_d[1]) > max_d[0]:
                    ratio = max_d[0] / getattr(img, max_d[1])
                    img.width  = int(img.width  * ratio)
                    img.height = int(img.height * ratio)
            ws.add_image(img)
        except Exception as ex:
            ws["A7"] = f"⚠ Image non intégrée : {ex}"
            ws["A7"].font = font(size=9, italic=True, color="CC0000")

    # ── Excel .xlsx → copie contenu ──
    elif ext == ".xlsx":
        try:
            src = openpyxl.load_workbook(full_path, data_only=True)
            sw  = src.active
            ws["A7"] = f"Contenu de : {basename}"
            ws["A7"].font = font(size=9, bold=True)
            ro = 8
            for src_row in sw.iter_rows(values_only=True):
                for ci, val in enumerate(src_row, 1):
                    if val is not None:
                        ws.cell(ro, ci, str(val)).font = font(size=9)
                ro += 1
                if ro > 500:
                    ws.cell(ro, 1, "… (tronqué à 500 lignes)").font = font(
                        size=8, italic=True, color="888888")
                    break
        except Exception as ex:
            ws["A7"] = f"⚠ Impossible de lire : {ex}"
            ws["A7"].font = font(size=9, italic=True, color="CC0000")

    # ── Excel .xls (ancien format) → converti via xlrd ──
    elif ext == ".xls":
        try:
            import xlrd
            src  = xlrd.open_workbook(full_path)
            sw   = src.sheet_by_index(0)
            ws["A7"] = f"Contenu de : {basename}  (format .xls converti)"
            ws["A7"].font = font(size=9, bold=True)
            ro = 8
            for rx in range(sw.nrows):
                for ci, val in enumerate(sw.row_values(rx), 1):
                    if val != "":
                        ws.cell(ro, ci, str(val)).font = font(size=9)
                ro += 1
                if ro > 500:
                    ws.cell(ro, 1, "… (tronqué à 500 lignes)").font = font(
                        size=8, italic=True, color="888888")
                    break
        except ImportError:
            # xlrd pas installé → on copie quand même le chemin
            ws["A7"] = "⚠ Installer xlrd pour lire les .xls :  pip install xlrd"
            ws["A7"].font = font(size=9, italic=True, color="CC0000")
            ws["A8"] = full_path
            ws["A8"].font = font(size=9, color=SG_RED.lstrip("#"))
        except Exception as ex:
            ws["A7"] = f"⚠ Impossible de lire .xls : {ex}"
            ws["A7"].font = font(size=9, italic=True, color="CC0000")

    # ── CSV → copie contenu ──
    elif ext == ".csv":
        try:
            import csv
            ws["A7"] = f"Contenu de : {basename}"
            ws["A7"].font = font(size=9, bold=True)
            ro = 8
            with open(full_path, encoding="utf-8", errors="replace") as f:
                reader = csv.reader(f)
                for src_row in reader:
                    for ci, val in enumerate(src_row, 1):
                        if val:
                            ws.cell(ro, ci, val).font = font(size=9)
                    ro += 1
                    if ro > 500:
                        break
        except Exception as ex:
            ws["A7"] = f"⚠ Impossible de lire CSV : {ex}"
            ws["A7"].font = font(size=9, italic=True, color="CC0000")

    # ── PDF / Word / autres → chemin + note ──
    else:
        ws["A7"] = "📄 Fichier joint (ouvrir manuellement) :"
        ws["A7"].font = font(size=10, bold=True)
        ws["B7"] = full_path
        ws["B7"].font = font(size=9, color=SG_RED.lstrip("#"))
        ws.merge_cells("A8:F8")
        ws["A8"] = f"ℹ  Le format {ext.upper()} ne peut pas être intégré directement — le chemin est conservé ci-dessus."
        ws["A8"].font = font(size=8, italic=True, color="888888")
